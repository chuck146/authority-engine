# ============================================
# Authority Engine — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Server-side only, never expose

# --- Auth ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI: Text Generation ---
ANTHROPIC_API_KEY=sk-ant-your-key

# --- AI: Image Generation (Nano Banana 2) ---
GOOGLE_AI_API_KEY=your-gemini-api-key

# --- AI: Video Generation (Veo 3.1) ---
# Uses same GOOGLE_AI_API_KEY above

# --- Background Jobs ---
REDIS_URL=redis://localhost:6379
# Or Upstash: REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# --- Storage ---
CLOUDFLARE_R2_ACCESS_KEY=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET=authority-engine
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# --- Email ---
RESEND_API_KEY=re_your-key

# --- Google Integrations (MVP) ---
GOOGLE_SEARCH_CONSOLE_CREDENTIALS=  # OAuth2 JSON
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_BUSINESS_PROFILE_ACCOUNT=

# --- CRM ---
HUBSPOT_ACCESS_TOKEN=your-token
HUBSPOT_PORTAL_ID=21546007

# --- Project Management ---
CLICKUP_API_TOKEN=your-token
CLICKUP_PROJECTS_LIST_ID=901320531655

# --- Notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# --- V2 Milestone (not needed for MVP) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# BRAND24_API_KEY=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
